{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,

    "paths": {
      "@components/*": ["./src/components/*"],
      "@components": ["./src/components"],
      "@pages/*": ["./src/pages/*"],
      "@pages": ["./src/pages"],
      "@hooks/*": ["./src/hooks/*"],
      "@hooks": ["./src/hooks"],
      "@services/*": ["./src/services/*"],
      "@services": ["./src/services"],
      "@styles/*": ["./src/styles/*"],
      "@styles": ["./src/styles"],
      "@common/*": ["./src/common/*"],
      "@common": ["./src/common/"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
